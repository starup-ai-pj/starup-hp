# Notion / Slack 連携の設定テンプレート
# 値を埋めて .env.local にコピーして使用する（実値はコミットしない）

# --- Notion 共通 ---
# Notion Integration トークン。対象 DB の Connections に Integration を追加しておくこと
NOTION_API_KEY=

# --- 表示（お知らせ / 採用情報の取得元データベース）---
NOTION_NEWS_DATABASE_ID=
NOTION_RECRUIT_DATABASE_ID=

# --- フォーム送信（登録先データソース）---
# お問い合わせフォーム（/api/contact）の登録先
NOTION_DATA_SOURCE_ID=
# 採用応募フォーム（/api/recruit）の登録先
NOTION_RECRUIT_DATA_SOURCE_ID=

# --- Slack 通知（お問い合わせ受信時）---
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# --- サイト URL（OGP 画像・Slack 通知アイコン等の絶対 URL 生成）---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
